# SQL Server (restored McLabor copy — read-only user recommended)
SQL_SERVER=localhost
SQL_DATABASE=McLabor
SQL_USER=
SQL_PASSWORD=
SQL_ENCRYPT=false
SQL_TRUST_CERT=true

# Session (min 32 characters)
SESSION_SECRET=change-me-to-a-long-random-string-at-least-32-chars

# Milestone 1 dev login (not Access passwords — replace before any shared environment)
DEV_LOGIN_USERNAME=dev
# Bcrypt hashes contain $ — Next.js expands $ in .env unless escaped:
# Option A (escaped): DEV_LOGIN_PASSWORD_HASH=\$2b\$10\$...full-hash...
# Option B (base64):  DEV_LOGIN_PASSWORD_HASH=JDJiJDEwJ...base64-of-full-hash...
DEV_LOGIN_PASSWORD_HASH=
DEV_LOGIN_DISPLAY_NAME=Dev User
